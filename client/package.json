{
  "name": "synclaw",
  "version": "1.0.0",
  "description": "AI Agent Desktop Client - 让用户拥有炫酷的桌面 AI 助手",
  "type": "module",
  "main": "dist/main/index.js",
  "author": "SynClaw Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-main.mjs",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-main.mjs",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run openclaw:sync && npm run build && electron-builder",
    "electron:build:mac": "npm run openclaw:sync && npm run build && electron-builder --mac --publish never",
    "electron:build:win": "npm run openclaw:sync && npm run build && electron-builder --win",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "openclaw:sync": "node scripts/sync-openclaw-version.mjs",
    "openclaw:download": "node scripts/download-openclaw.mjs",
    "openclaw:update": "npm run openclaw:sync && npm run openclaw:download"
  },
  "openclawVersion": "2026.3.28",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/ws": "^8.18.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^10.16.16",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "ws": "^8.19.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  }
}
