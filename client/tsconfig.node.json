{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "outDir": "dist",
    "noEmit": false
  },
  "include": ["src/main/**/*", "src/preload/**/*", "vite.config.ts"]
}
