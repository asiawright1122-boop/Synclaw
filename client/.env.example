# ── SynClaw Desktop Client ────────────────────────────────────────────────

# Gateway 端口（默认 18789，通常不需要修改）
GATEWAY_PORT=18789

# 自动更新 Feed URL（留空则禁用自动更新）
# 生产环境示例：https://releases.synclaw.ai/latest
UPDATER_FEED_URL=

# 开发模式（设为 1 跳过 Gateway 连接检查）
DEV_GATEWAY_SKIP_CHECK=0

# ── 代码签名 & macOS 公证 ──────────────────────────────────────────────────
#
# macOS Notarization 要求（需付费 Apple Developer 账号）：
#
# 1. APPLE_ID           — 你的 Apple 账号邮箱（developer.apple.com）
# 2. APPLE_TEAM_ID      — 团队 ID（https://developer.apple.com/account → embership）
# 3. APPLE_APP_SPECIFIC_PASSWORD — 应用专用密码
#    生成方法：appleid.apple.com → 登录 → 安全 → 应用专用密码 → 生成
# 4. CSC_LINK           — 代码签名证书路径或 Base64（.p12/.cer）
# 5. CSC_KEY_PASSWORD   — 证书密钥密码
#
# 警告：不要将实际凭据提交到仓库！
# 本地开发时使用 .env.local；CI 中通过 GitHub Secrets 配置。
#
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=
CSC_LINK=
CSC_KEY_PASSWORD=

# ── 安全 ────────────────────────────────────────────────────────────────

# Settings 存储加密密钥（必填生产环境）
# 运行以下命令生成：openssl rand -hex 32
# 留空则使用明文存储（不推荐生产环境）
STORE_ENCRYPTION_KEY=
